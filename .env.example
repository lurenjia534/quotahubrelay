GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_SECRET=
AUTH_BASE_URL=http://localhost:3000
# Better Auth also reads these names. Prefer them for new deployments.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Local development defaults to SQLite when DATABASE_URL is unset.
SQLITE_DATABASE_PATH=auth.sqlite

# Production on Vercel should set DATABASE_URL to Postgres.
# DATABASE_URL=postgres://user:password@host:5432/database
