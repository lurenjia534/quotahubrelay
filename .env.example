# GitHub OAuth app credentials.
# GitHub OAuth 应用凭据。
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated email allowlist. Leave no spaces around commas.
# 允许登录的邮箱白名单，多个邮箱用英文逗号分隔，逗号两侧不要加空格。
AUTH_ALLOWED_EMAILS=

# Better Auth secret and public base URL.
# Better Auth 密钥和公开基础 URL。
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Local development defaults to SQLite when DATABASE_URL is unset.
# 本地开发未设置 DATABASE_URL 时默认使用 SQLite。
SQLITE_DATABASE_PATH=auth.sqlite

# Production on Vercel should set DATABASE_URL to Postgres.
# Vercel 生产环境建议设置 DATABASE_URL，使用 Postgres。
# DATABASE_URL=postgres://user:password@host:5432/database
